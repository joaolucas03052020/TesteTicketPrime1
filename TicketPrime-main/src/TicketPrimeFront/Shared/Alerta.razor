@if (!string.IsNullOrEmpty(Mensagem))
{
    <div class="tp-alert tp-alert-@Tipo">
        <span>@(Tipo == "sucesso" ? "✅" : "❌")</span>
        <span>@Mensagem</span>
    </div>
}

@code {
    [Parameter] public string Mensagem { get; set; } = string.Empty;
    [Parameter] public string Tipo { get; set; } = "erro"; // "sucesso" ou "erro"
}
