@page "/"
<PageTitle>TicketPrime — Início</PageTitle>

<div class="tp-hero">
    <div class="tp-hero-icon">🎟</div>
    <h1 class="tp-hero-title">TicketPrime</h1>
    <p class="tp-hero-sub">Motor de vendas de ingressos rápido, seguro e escalável.</p>
</div>

<div class="tp-cards-grid">
    <a href="eventos" class="tp-card tp-card-link">
        <div class="tp-card-icon">📅</div>
        <div class="tp-card-title">Eventos</div>
        <div class="tp-card-desc">Cadastre e visualize eventos disponíveis.</div>
    </a>
    <a href="usuarios" class="tp-card tp-card-link">
        <div class="tp-card-icon">👤</div>
        <div class="tp-card-title">Usuários</div>
        <div class="tp-card-desc">Registre compradores com CPF único.</div>
    </a>
    <a href="cupons" class="tp-card tp-card-link">
        <div class="tp-card-icon">🏷</div>
        <div class="tp-card-title">Cupons</div>
        <div class="tp-card-desc">Gerencie descontos com regra de valor mínimo.</div>
    </a>
    <a href="reservas" class="tp-card tp-card-link">
        <div class="tp-card-icon">🎫</div>
        <div class="tp-card-title">Reservas</div>
        <div class="tp-card-desc">Realize compras de ingressos com segurança.</div>
    </a>
</div>
