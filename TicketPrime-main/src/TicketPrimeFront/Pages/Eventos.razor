@page "/eventos"
@inject HttpClient Http
<PageTitle>Eventos — TicketPrime</PageTitle>

<h1 class="tp-page-title">📅 Eventos</h1>

<div class="tp-two-col">

    <!-- FORMULÁRIO DE CADASTRO -->
    <div class="tp-card">
        <h2 class="tp-card-title">Cadastrar Evento</h2>
        <div class="tp-form">
            <label class="tp-label">Nome do evento</label>
            <input class="tp-input" @bind="novoEvento.Nome" placeholder="Ex: Festival de Verão 2025" />

            <label class="tp-label">Data do evento</label>
            <input class="tp-input" type="datetime-local" @bind="novoEvento.DataEvento" />

            <label class="tp-label">Capacidade total</label>
            <input class="tp-input" type="number" @bind="novoEvento.CapacidadeTotal" placeholder="Ex: 500" />

            <label class="tp-label">Preço padrão (R$)</label>
            <input class="tp-input" type="number" step="0.01" @bind="novoEvento.PrecoPadrao" placeholder="Ex: 150.00" />

            <button class="tp-btn tp-btn-primary" @onclick="CadastrarEvento" disabled="@carregandoPost">
                @(carregandoPost ? "Salvando..." : "Cadastrar")
            </button>

            <Alerta Mensagem="@mensagem" Tipo="@tipoMensagem" />
        </div>
    </div>

    <!-- LISTAGEM -->
    <div class="tp-card">
        <div class="tp-card-header">
            <h2 class="tp-card-title">Eventos Disponíveis</h2>
            <button class="tp-btn tp-btn-ghost" @onclick="CarregarEventos">↻ Atualizar</button>
        </div>

        @if (carregandoGet)
        {
            <p class="tp-loading">Carregando eventos...</p>
        }
        else if (eventos is null || !eventos.Any())
        {
            <p class="tp-empty">Nenhum evento cadastrado.</p>
        }
        else
        {
            <div class="tp-list">
                @foreach (var ev in eventos)
                {
                    <div class="tp-list-item">
                        <div class="tp-list-main">
                            <span class="tp-list-title">@ev.Nome</span>
                            <span class="tp-badge">ID @ev.Id</span>
                        </div>
                        <div class="tp-list-detail">
                            📅 @ev.DataEvento.ToString("dd/MM/yyyy HH:mm") &nbsp;|&nbsp;
                            👥 @ev.CapacidadeTotal vagas &nbsp;|&nbsp;
                            💰 R$ @ev.PrecoPadrao.ToString("F2")
                        </div>
                    </div>
                }
            </div>
        }
    </div>

</div>

@code {
    private Evento novoEvento = new() { DataEvento = DateTime.Now.AddDays(1) };
    private List<Evento>? eventos;
    private string mensagem = string.Empty;
    private string tipoMensagem = "erro";
    private bool carregandoGet = false;
    private bool carregandoPost = false;

    protected override async Task OnInitializedAsync()
    {
        await CarregarEventos();
    }

    private async Task CarregarEventos()
    {
        carregandoGet = true;
        try
        {
            eventos = await Http.GetFromJsonAsync<List<Evento>>("/api/eventos");
        }
        catch
        {
            eventos = new();
        }
        carregandoGet = false;
    }

    private async Task CadastrarEvento()
    {
        mensagem = string.Empty;
        carregandoPost = true;

        var resp = await Http.PostAsJsonAsync("/api/eventos", novoEvento);
        if (resp.IsSuccessStatusCode)
        {
            mensagem = "Evento cadastrado com sucesso!";
            tipoMensagem = "sucesso";
            novoEvento = new() { DataEvento = DateTime.Now.AddDays(1) };
            await CarregarEventos();
        }
        else
        {
            mensagem = await resp.Content.ReadAsStringAsync();
            tipoMensagem = "erro";
        }

        carregandoPost = false;
    }
}
